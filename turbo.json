{
  "$schema": "https://v2-10-1.turborepo.dev/schema.json",
  "ui": "stream",
  "tasks": {
    "build": {
      "passThroughEnv": [
        "SYSTEMROOT",
        "WINDIR",
        "COMSPEC",
        "PATHEXT",
        "PATH",
        "TEMP",
        "TMP",
        "APPDATA",
        "LOCALAPPDATA",
        "USERPROFILE",
        "HOMEDRIVE",
        "HOMEPATH"
      ],
      "env": [
        "NODE_ENV",
        "PRIVATE_MAPS_KEY",
        "PUBLIC_MAPS_URL",
        "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "PUBLIC_SUPABASE_URL",
        "PUBLIC_SUPABASE_PUBLISHABLE_KEY",
        "PRIVATE_SUPABASE_SECRET_KEY",
        "PRIVATE_EMAIL_HOST",
        "PRIVATE_EMAIL_PORT",
        "PRIVATE_EMAIL_USER",
        "PRIVATE_EMAIL_PASS",
        "PRIVATE_EMAIL_ADDRESS",
        "SUPABASE_SECRET_KEY",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "NEXT_PUBLIC_WEBAPP_URL",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_WEBSITE_URL",
        "PRIVATE_CHROME_EXTENSION_ID",
        "PRIVATE_CHROME_PUBLISHER_ID",
        "PRIVATE_CHROME_SERVICE_ACCOUNT_KEY_JSON",
        "PRIVATE_CHROME_PRIVATE_SIGNING_KEY",
        "PRIVATE_CHROME_PUBLIC_SIGNING_KEY",
        "DO_NOT_TRACK"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/chrome-extension/.env.production.local",
        "apps/web/.env.production.local",
        "apps/webapp/.env.production.local",
        "apps/website/.env.production.local",
        "apps/api/.env.production.local"
      ],
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "public/**"]
    },

    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "passThroughEnv": [
        "SYSTEMROOT",
        "WINDIR",
        "COMSPEC",
        "PATHEXT",
        "PATH",
        "TEMP",
        "TMP",
        "APPDATA",
        "LOCALAPPDATA",
        "USERPROFILE",
        "HOMEDRIVE",
        "HOMEPATH"
      ]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": true,
      "env": [
        "NEXT_PUBLIC_WEBAPP_URL",
        "PRIVATE_MAPS_KEY",
        "PUBLIC_MAPS_URL",
        "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "PUBLIC_SUPABASE_URL",
        "PUBLIC_SUPABASE_PUBLISHABLE_KEY",
        "PRIVATE_SUPABASE_SECRET_KEY",
        "PRIVATE_EMAIL_HOST",
        "PRIVATE_EMAIL_PORT",
        "PRIVATE_EMAIL_USER",
        "PRIVATE_EMAIL_PASS",
        "PRIVATE_EMAIL_ADDRESS",
        "SUPABASE_SECRET_KEY",
        "GITHUB_CLIENT_ID",
        "GITHUB_CLIENT_SECRET",
        "NEXT_PUBLIC_WEBAPP_URL",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_WEBSITE_URL",
        "DO_NOT_TRACK"
      ],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/chrome-extension/.env.development.local",
        "apps/web/.env.development.local",
        "apps/webapp/.env.development.local",
        "apps/website/.env.development.local",
        "apps/api/.env.development.local"
      ]
    },
    "@bondery/branding#build": {
      "outputs": ["dist/**"],
      "env": []
    },
    "@bondery/emails#build": {
      "dependsOn": ["@bondery/branding#build", "@bondery/mantine-next#build"],
      "outputs": ["dist/**"],
      "env": []
    },
    "@bondery/helpers#build": {
      "dependsOn": ["@bondery/schemas#build"],
      "outputs": ["dist/**"],
      "env": []
    },
    "@bondery/schemas#build": {
      "outputs": ["dist/**"],
      "env": []
    },
    "@bondery/vcard#build": {
      "dependsOn": ["@bondery/helpers#build", "@bondery/schemas#build"],
      "outputs": ["dist/**"],
      "env": []
    },
    "start": {
      "persistent": true,
      "cache": false
    }
  },
  "globalPassThroughEnv": [
    "PATH",
    "PATHEXT",
    "SYSTEMROOT",
    "WINDIR",
    "COMSPEC",
    "TEMP",
    "TMP",
    "APPDATA",
    "LOCALAPPDATA",
    "USERPROFILE",
    "HOMEDRIVE",
    "HOMEPATH",
    "ProgramFiles",
    "ProgramFiles(x86)",
    "ProgramW6432",
    "PRIVATE_MAPS_KEY",
    "PUBLIC_MAPS_URL",
    "NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "PUBLIC_SUPABASE_URL",
    "PUBLIC_SUPABASE_PUBLISHABLE_KEY",
    "PRIVATE_SUPABASE_SECRET_KEY",
    "PRIVATE_EMAIL_HOST",
    "PRIVATE_EMAIL_PORT",
    "PRIVATE_EMAIL_USER",
    "PRIVATE_EMAIL_PASS",
    "PRIVATE_EMAIL_ADDRESS",
    "SUPABASE_SECRET_KEY",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "NEXT_PUBLIC_WEBAPP_URL",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WEBSITE_URL",
    "PRIVATE_CHROME_EXTENSION_ID",
    "PRIVATE_CHROME_PUBLISHER_ID",
    "PRIVATE_CHROME_SERVICE_ACCOUNT_KEY_JSON",
    "PRIVATE_CHROME_PRIVATE_SIGNING_KEY",
    "PRIVATE_CHROME_PUBLIC_SIGNING_KEY",
    "DO_NOT_TRACK"
  ]
}
