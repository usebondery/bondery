# Generated by npm run env — do not edit by hand. Edit root .env.local instead.


# --- Public URLs ---
# Public API base URL (no trailing /api)
BONDERY_PUBLIC_API_URL=http://localhost:26631
# Public webapp origin
BONDERY_PUBLIC_WEBAPP_URL=http://localhost:26632
# Public marketing website origin
BONDERY_PUBLIC_WEBSITE_URL=http://localhost:26630
# Comma-separated extra CORS origins (e.g. Expo web)
BONDERY_PUBLIC_EXTRA_ALLOWED_ORIGINS=http://localhost:26634

# --- Supabase ---
# Supabase project URL (OAuth provider redirect_uri is derived as {url}/auth/v1/callback)
BONDERY_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Supabase publishable (anon) key
BONDERY_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
# Supabase secret (service role) key
BONDERY_PRIVATE_SUPABASE_SECRET_KEY=sb_secret_<your-secret-key>
# Compact single-line JWT signing JWK JSON
BONDERY_PRIVATE_SUPABASE_JWT_SIGNING_JWK="{\"kty\":\"EC\",\"kid\":\"<your-kid>\",\"use\":\"sig\",\"alg\":\"ES256\",\"crv\":\"P-256\",\"d\":\"<private-d>\",\"x\":\"<public-x>\",\"y\":\"<public-y>\"}"
# Chrome extension OAuth client id (Supabase Dashboard)
BONDERY_PUBLIC_SUPABASE_OAUTH_CLIENT_ID=""

# --- Supabase Auth (local) ---
# GitHub OAuth client id for local Supabase Auth
BONDERY_SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=""
# GitHub OAuth client secret for local Supabase Auth
BONDERY_SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=""
# LinkedIn OAuth client id for local Supabase Auth
BONDERY_SUPABASE_AUTH_EXTERNAL_LINKEDIN_CLIENT_ID=""
# LinkedIn OAuth client secret for local Supabase Auth
BONDERY_SUPABASE_AUTH_EXTERNAL_LINKEDIN_SECRET=""

# --- API secrets ---
# Pepper for hashing API keys
BONDERY_PRIVATE_API_KEY_PEPPER=<your-api-key-pepper>

# --- Email ---
# SMTP host
BONDERY_PRIVATE_EMAIL_HOST=smtp.example.com
# SMTP port
BONDERY_PRIVATE_EMAIL_PORT=465
# SMTP username
BONDERY_PRIVATE_EMAIL_USER=robot@example.com
# SMTP password
BONDERY_PRIVATE_EMAIL_PASS=your-email-password
# From address for transactional email
BONDERY_PRIVATE_EMAIL_ADDRESS=robot@example.com

# --- Redis ---
# Redis connection URL
BONDERY_PRIVATE_REDIS_URL=redis://127.0.0.1:26636

# --- Polar ---
# Polar.sh API access token
BONDERY_PRIVATE_POLAR_ACCESS_TOKEN=<your-polar-access-token>
# Polar.sh webhook secret
BONDERY_PRIVATE_POLAR_WEBHOOK_SECRET=<your-polar-webhook-secret>
# Polar environment (sandbox | production)
BONDERY_PUBLIC_POLAR_ENVIRONMENT=sandbox
# Polar product id for checkout
BONDERY_PUBLIC_POLAR_PRODUCT_ID=<your-polar-product-id>

# --- Maps ---
# Mapy.com API base URL
BONDERY_PUBLIC_MAPS_URL=https://api.mapy.com
# Mapy.com API key
BONDERY_PRIVATE_MAPS_KEY=<your-maps-api-key>

# --- AI ---
# Anthropic API key for AI features
BONDERY_PRIVATE_ANTHROPIC_API_KEY=sk-ant-<your-anthropic-api-key>

# --- Analytics ---
# PostHog project API key (browser)
BONDERY_PUBLIC_POSTHOG_KEY=""
# PostHog host URL
BONDERY_PUBLIC_POSTHOG_HOST=""
# PostHog personal/project key for server-side capture (optional)
BONDERY_PRIVATE_POSTHOG_KEY=""
# PostHog host for server-side capture (optional)
BONDERY_PRIVATE_POSTHOG_HOST=""
# PostHog personal API key for admin analytics queries (optional)
BONDERY_PRIVATE_POSTHOG_API_SECRET=""
# PostHog project id for admin analytics queries (optional)
BONDERY_PRIVATE_POSTHOG_PROJECT_ID=""
# Disable analytics / vendor telemetry when true
DO_NOT_TRACK=true

# --- Infra ---
# App version surfaced in webapp runtime config
BONDERY_INFRA_VERSION=""
# Git SHA surfaced in webapp runtime config
BONDERY_INFRA_GIT_SHA=""
# Compose-internal API URL (production webapp only)
BONDERY_INFRA_INTERNAL_API_URL=""

# --- Mobile ---
# Mobile sync debug logging (1/true)
BONDERY_PUBLIC_SYNC_DEBUG=""
