{
	"servers": {
		"plane": {
			"command": "npx",
			"args": [
				"mcp-remote@latest",
				"https://mcp.plane.so/http/mcp"
			],
			"type": "stdio"
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/"
		},
		"Vercel": {
			"url": "https://mcp.vercel.com",
			"type": "http"
		},
		"chrome-devtools": {
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp@latest"
			],
			"type": "stdio"
		},
		"MCP_DOCKER": {
			"command": "docker",
			"args": [
				"mcp",
				"gateway",
				"run"
			],
			"env": {
				"LOCALAPPDATA": "C:\\Users\\msmar\\AppData\\Local",
				"ProgramData": "C:\\ProgramData",
				"ProgramFiles": "C:\\Program Files"
			},
			"type": "stdio"
		},
		"supabase": {
			"url": "http://localhost:54321/mcp",
			"type": "http"
		},
		    "mantine": {
      "command": "npx",
      "args": ["-y", "@mantine/mcp-server"],
      "env": {
        "MANTINE_MCP_DATA_URL": "https://mantine.dev/mcp"
      }
    }

	},
	"inputs": []
}