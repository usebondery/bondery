{
  "tasks": [
    {
      "args": ["scripts/start-ngrok-config.mjs", "ngrok.yml"],
      "command": "node",
      "isBackground": true,
      "label": "ngrok: ngrok.yml",
      "linux": {
        "options": {
          "cwd": "${workspaceFolder}",
          "env": {
            "PATH": "/snap/bin:/usr/local/bin:/usr/bin:/bin:${env:PATH}"
          },
          "shell": {
            "args": ["-lc"],
            "executable": "/bin/bash"
          }
        }
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "group": "ngrok",
        "panel": "dedicated",
        "reveal": "silent"
      },
      "problemMatcher": {
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(started tunnel|Tunnel session established)"
        },
        "owner": "ngrok",
        "pattern": { "regexp": "^$" }
      },
      "type": "shell"
    },
