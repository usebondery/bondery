{
  "tasks": [
    {
      "args": ["scripts/start-ngrok-config.mjs", "ngrok.yml"],
      "command": "node",
      "isBackground": true,
      "label": "ngrok: ngrok.yml",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "group": "ngrok",
        "panel": "dedicated",
        "reveal": "silent"
      },
      "problemMatcher": {
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(started tunnel|Tunnel session established)"
        },
        "owner": "ngrok",
        "pattern": { "regexp": "^$" }
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "type": "shell"
    },
