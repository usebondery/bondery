{
  "$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on",
        "useSortedAttributes": "on",
        "useSortedEnumMembers": "on",
        "useSortedInterfaceMembers": "on",
        "useSortedKeys": "on"
      }
    },
    "enabled": true
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.next",
      "!**/out",
      "!**/build",
      "!**/.parcel-cache",
      "!**/next-env.d.ts",
      "!**/*.svg",
      "!**/Untitled-1.html",
      "!**/*.generated.ts",
      "!**/generated",
      "!packages/schemas/src/supabase.types.ts",
      "!packages/schemas/src/openapi/fixtures"
    ]
  },
  "formatter": {
    "attributePosition": "auto",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "html": {
    "formatter": {
      "indentScriptAndStyle": false,
      "selfCloseVoidElements": "always"
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "attributePosition": "auto",
      "bracketSameLine": false,
      "bracketSpacing": true,
      "jsxQuoteStyle": "double",
      "quoteProperties": "asNeeded",
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": {
        "noSvgWithoutTitle": "off"
      },
      "preset": "recommended",
      "style": {
        "noExcessiveLinesPerFile": {
          "level": "error",
          "options": {
            "maxLines": 500
          }
        },
        "useBlockStatements": "error"
      },
      "suspicious": {
        "noConsole": "error",
        "noUndeclaredEnvVars": {
          "level": "error",
          "options": {
            "allowedEnvVars": ["DEV", "WXT_.*", "CHECK_.*_STRICT", "DEBUG_RUN_ID", "NGROK"]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "**/scripts/**",
        "**/scripts/*",
        "packages/helpers/src/env/check-env.ts",
        "apps/chrome-extension/wxt.config.ts"
      ],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ],
  "vcs": {
    "clientKind": "git",
    "enabled": true,
    "useIgnoreFile": true
  }
}
