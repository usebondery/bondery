# Compose knobs (Path A — API + bundled Redis)
API_IMAGE_TAG=production
PRIVATE_REDIS_URL=redis://redis:6379

# Copy remaining production secrets from apps/api/.env.production.example into this .env
# (or into Dokploy environment variables). Required for the API to boot.

# Path B (external / managed Redis):
# Do not use this compose Redis service. Run the API image alone and set:
# PRIVATE_REDIS_URL=rediss://:token@your-host:6379
