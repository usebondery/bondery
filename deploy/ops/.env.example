# =============================================================================
# Bondery ops (marketing website) — copy to .env for Dokploy / local smoke
# docker compose -f deploy/ops/docker-compose.yml --env-file deploy/ops/.env up -d
#
# Image is hardcoded to ghcr.io/usebondery/website:production (no tag env var).
# =============================================================================

# Public hostnames (no scheme). Compose derives https://… URLs and Traefik Host().
BONDERY_INFRA_WEBAPP_DOMAIN=app.usebondery.com
BONDERY_INFRA_WEBSITE_DOMAIN=usebondery.com

# Optional build metadata surfaced in the container
BONDERY_INFRA_GIT_SHA=
