# =============================================================================
# Bondery stack — copy to .env and fill secrets
# docker compose -f deploy/bondery/docker-compose.yml --env-file deploy/bondery/.env up -d
# =============================================================================

# --- Image tags (optional) ---
# Omit to pull the floating "production" channel. Pin to semver (e.g. 1.7.3) for
# reproducible deploys / explicit rollback.
# BONDERY_INFRA_API_IMAGE_TAG=1.7.3
# BONDERY_INFRA_WEBAPP_IMAGE_TAG=1.7.3

# --- Public hostnames (no scheme) ---
# Traefik Host() rules use these; Compose derives https://… URLs for the apps.
BONDERY_INFRA_API_DOMAIN=api.usebondery.com
BONDERY_INFRA_WEBAPP_DOMAIN=app.usebondery.com
BONDERY_INFRA_WEBSITE_DOMAIN=usebondery.com

# --- Bundled Redis (default). Advanced: run API alone with a managed Redis URL. ---
BONDERY_PRIVATE_REDIS_URL=redis://redis:6379

# --- Supabase (same project for API + webapp; publishable key is public by design) ---
BONDERY_PUBLIC_SUPABASE_URL=https://<your-project-id>.supabase.co
BONDERY_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_<your-publishable-key>
BONDERY_PRIVATE_SUPABASE_SECRET_KEY=sb_secret_<your-secret-key>
# MUST be compact single-line JSON (no newlines) — multiline breaks Compose/Dokploy .env parsing
BONDERY_PRIVATE_SUPABASE_JWT_SIGNING_JWK={"kty":"EC","kid":"<your-kid>","use":"sig","alg":"ES256","crv":"P-256","d":"<private-d>","x":"<public-x>","y":"<public-y>"}

# --- API secrets (env_file → api only; never injected into webapp) ---
BONDERY_PRIVATE_API_KEY_PEPPER=<your-api-key-pepper>

BONDERY_PRIVATE_EMAIL_HOST=smtp.example.com
BONDERY_PRIVATE_EMAIL_PORT=465
BONDERY_PRIVATE_EMAIL_USER=username
BONDERY_PRIVATE_EMAIL_PASS=your-email-password
BONDERY_PRIVATE_EMAIL_ADDRESS=robot@usebondery.com

BONDERY_PRIVATE_POLAR_WEBHOOK_SECRET=<your-polar-webhook-secret>
BONDERY_PRIVATE_POLAR_ACCESS_TOKEN=<your-polar-access-token>
BONDERY_PUBLIC_POLAR_ENVIRONMENT=production
BONDERY_PUBLIC_POLAR_PRODUCT_ID=<your-polar-product-id>

# Optional integrations (API)
BONDERY_PRIVATE_ANTHROPIC_API_KEY=
BONDERY_PUBLIC_MAPS_URL=https://api.mapy.com
BONDERY_PRIVATE_MAPS_KEY=

# Optional webapp analytics (allowlisted into webapp only)
BONDERY_PUBLIC_POSTHOG_KEY=
BONDERY_PUBLIC_POSTHOG_HOST=
BONDERY_PRIVATE_POSTHOG_KEY=
BONDERY_PRIVATE_POSTHOG_HOST=

# Optional API admin analytics (env_file → api only)
BONDERY_PRIVATE_POSTHOG_API_SECRET=
BONDERY_PRIVATE_POSTHOG_PROJECT_ID=

# Optional build metadata (surfaced in webapp runtime config / status)
BONDERY_INFRA_VERSION=1.7.3
BONDERY_INFRA_GIT_SHA=
