# =============================================================================
# Bondery stack — copy to .env and fill secrets
# docker compose -f deploy/bondery/docker-compose.yml --env-file deploy/bondery/.env up -d
# =============================================================================

# --- Image tags (optional) ---
# Omit to pull the floating "production" channel. Pin to semver (e.g. 1.7.4) for
# reproducible deploys / explicit rollback.
# BONDERY_INFRA_API_IMAGE_TAG=1.7.4
# BONDERY_INFRA_WEBAPP_IMAGE_TAG=1.7.4

# --- Public hostnames (no scheme) ---
# Traefik Host() rules use these; Compose derives https://… URLs for the apps.
BONDERY_INFRA_API_DOMAIN=api.usebondery.com
BONDERY_INFRA_WEBAPP_DOMAIN=app.usebondery.com
BONDERY_INFRA_WEBSITE_DOMAIN=usebondery.com
BONDERY_INFRA_SUPABASE_DOMAIN=supabase.usebondery.com
# Chrome Web Store ID — Compose adds https://{id}.chromiumapp.org(/) to Auth allow-list.
BONDERY_INFRA_CHROME_EXTENSION_ID=lpcmokfekjjejnpobhbkgmjkodfhpmha

# --- Bundled Redis (default). Advanced: run API alone with a managed Redis URL. ---
BONDERY_PRIVATE_REDIS_URL=redis://redis:6379

# --- Bundled Supabase (self-host) ---
# Generate JWT_SECRET + anon/service keys with upstream helpers, then map into BONDERY_*:
#   https://supabase.com/docs/guides/self-hosting/docker#configuring-and-securing-supabase
# BONDERY_PUBLIC_SUPABASE_URL is derived from BONDERY_INFRA_SUPABASE_DOMAIN (do not set).
# sb_publishable_* / sb_secret_* opaque API keys (not legacy eyJ… JWT keys).
BONDERY_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_WITH_YOUR_KEY
BONDERY_PRIVATE_SUPABASE_SECRET_KEY=sb_secret_REPLACE_WITH_YOUR_KEY
BONDERY_PRIVATE_SUPABASE_JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
# MUST be compact single-line JSON (no newlines) — multiline breaks Compose/Dokploy .env parsing.
# Required at compose project level (not only on the api service) so jwt-derive can wire Auth JWKS.
BONDERY_PRIVATE_SUPABASE_JWT_SIGNING_JWK={"kty":"EC","kid":"<your-kid>","use":"sig","alg":"ES256","crv":"P-256","d":"<private-d>","x":"<public-x>","y":"<public-y>"}

# Postgres + Supabase encrypt keys (generate once; never rotate casually)
BONDERY_PRIVATE_POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
# openssl rand -base64 48
BONDERY_PRIVATE_SUPABASE_SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq
# openssl rand -base64 24 (≥32 chars)
BONDERY_PRIVATE_SUPABASE_PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min
# Studio / Kong dashboard basic-auth (profile studio only)
BONDERY_PRIVATE_SUPABASE_DASHBOARD_USERNAME=supabase
BONDERY_PRIVATE_SUPABASE_DASHBOARD_PASSWORD=this_password_is_insecure_and_should_be_updated

# Auth redirect allow-list (comma-separated): webapp/site callbacks + mobile deep links.
# Do not list chromiumapp.org here — derived from BONDERY_INFRA_CHROME_EXTENSION_ID.
BONDERY_SUPABASE_ADDITIONAL_REDIRECT_URLS=https://app.usebondery.com/auth/callback,https://usebondery.com/auth/callback,bondery://auth/callback,exp+bondery-mobile://auth/callback

# OAuth providers (GoTrue)
BONDERY_SUPABASE_AUTH_EXTERNAL_GITHUB_ENABLED=true
BONDERY_SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
BONDERY_SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=
BONDERY_SUPABASE_AUTH_EXTERNAL_LINKEDIN_ENABLED=true
BONDERY_SUPABASE_AUTH_EXTERNAL_LINKEDIN_CLIENT_ID=
BONDERY_SUPABASE_AUTH_EXTERNAL_LINKEDIN_SECRET=

# --- API secrets (env_file → api only; never injected into webapp) ---
BONDERY_PRIVATE_API_KEY_PEPPER=<your-api-key-pepper>

BONDERY_PRIVATE_EMAIL_HOST=smtp.example.com
BONDERY_PRIVATE_EMAIL_PORT=465
BONDERY_PRIVATE_EMAIL_USER=username
BONDERY_PRIVATE_EMAIL_PASS=your-email-password
BONDERY_PRIVATE_EMAIL_ADDRESS=robot@usebondery.com

BONDERY_PRIVATE_POLAR_WEBHOOK_SECRET=<your-polar-webhook-secret>
BONDERY_PRIVATE_POLAR_ACCESS_TOKEN=<your-polar-access-token>
BONDERY_PUBLIC_POLAR_ENVIRONMENT=production
BONDERY_PUBLIC_POLAR_PRODUCT_ID=<your-polar-product-id>

# Optional integrations (API)
BONDERY_PRIVATE_ANTHROPIC_API_KEY=
BONDERY_PUBLIC_MAPS_URL=https://api.mapy.com
BONDERY_PRIVATE_MAPS_KEY=

# Optional webapp analytics (allowlisted into webapp only)
BONDERY_PUBLIC_POSTHOG_KEY=
BONDERY_PUBLIC_POSTHOG_HOST=
BONDERY_PRIVATE_POSTHOG_KEY=
BONDERY_PRIVATE_POSTHOG_HOST=

# Optional API admin analytics (env_file → api only)
BONDERY_PRIVATE_POSTHOG_API_SECRET=
BONDERY_PRIVATE_POSTHOG_PROJECT_ID=

# Optional build metadata (surfaced in webapp runtime config / status)
BONDERY_INFRA_VERSION=1.7.4
BONDERY_INFRA_GIT_SHA=
