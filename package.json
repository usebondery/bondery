{
  "name": "bondery-monorepo",
  "version": "1.7.0",
  "private": true,
  "packageManager": "npm@11.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo watch dev",
    "dev:core": "turbo watch webapp#dev api#dev @bondery/emails#preview",
    "mobile": "turbo dev --filter=api --filter=mobile",
    "dev:extension": "turbo dev --filter=webapp --filter=api --filter=chrome-extension --filter=website",
    "dev:supabase": "turbo dev --filter=supabase-db",
    "dev:sync": "turbo dev --filter=api --filter=mobile",
    "dev:website": "turbo dev --filter=website",
    "dev:polar-webhook": "npx localtunnel --port 3001",
    "build": "turbo build",
    "build:api": "turbo build --filter=api",
    "build:webapp": "turbo build --filter=webapp",
    "build:website": "turbo build --filter=website",
    "build:chrome-extension": "turbo build --filter=chrome-extension",
    "turbo:clean": "turbo daemon clean",
    "start": "turbo start",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "check-types": "turbo check-types",
    "test:contracts": "npm run test:contracts -w @bondery/schemas",
    "check-openapi": "npm run generate-openapi -w apps/api && npm run check-openapi -w apps/api && npm run check-api-schema-patterns -w apps/api && npx redocly lint apps/api/openapi.yaml",
    "generate-openapi": "turbo generate-openapi --filter=api",
    "generate-types": "npm run gen-types -w apps/supabase-db && git add packages/schemas/src/supabase.types.ts",
    "sync-exports": "node scripts/sync-package-exports.mjs",
    "check-package-imports": "node scripts/check-package-import-extensions.mjs",
    "generate-doc-links": "node scripts/generate-doc-links.mjs",
    "check-doc-links": "node scripts/check-doc-links.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@redocly/cli": "^2.33.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.5",
    "turbo": "^2.10.2",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "freeport-async": "^2.0.0",
    "mcp-remote": "^0.1.38"
  },
  "allowScripts": {
    "core-js@3.49.0": true,
    "core-js-pure@3.49.0": true,
    "esbuild@0.28.1": true,
    "esbuild@0.27.7": true,
    "esbuild@0.27.4": true,
    "esbuild@0.28.0": true,
    "protobufjs@7.6.4": true,
    "sharp@0.34.5": true,
    "spawn-sync@1.0.15": true,
    "@parcel/watcher@2.5.6": true,
    "@swc/core@1.15.41": true
  }
}
