{
  "name": "bondery-monorepo",
  "version": "1.4.2",
  "private": true,
  "packageManager": "npm@11.12.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:core": "turbo dev --filter=webapp --filter=api --filter=@bondery/emails",
    "dev:extension": "turbo dev --filter=webapp --filter=api --filter=chrome-extension --filter=website",
    "dev:supabase": "turbo dev --filter=supabase-db",
    "dev:website": "turbo dev --filter=website",
    "dev:polar-webhook": "npx localtunnel --port 3001",
    "build": "turbo build",
    "start": "turbo start",
    "lint": "turbo lint",
    "format": "biome format --write .",
    "check-types": "turbo check-types",
    "generate-openapi": "npm run generate-openapi -w apps/api && git add apps/api/openapi.yaml",
    "generate-types": "npm run gen-types -w apps/supabase-db && git add packages/types/src/supabase.types.ts"
  },
  "pre-commit": [
    "generate-openapi"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@fastify/pre-commit": "^2.2.1",
    "@redocly/cli": "^2.24.1",
    "ajv": "^8.18.0",
    "turbo": "^2.9.5",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "mcp-remote": "^0.1.38"
  }
}
