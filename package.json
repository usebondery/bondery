{
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "@swc/core@1.15.43": true,
    "core-js-pure@3.49.0": true,
    "core-js@3.49.0": true,
    "esbuild@0.27.4": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.0": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.6.4": true,
    "sharp@0.34.5": true,
    "spawn-sync@1.0.15": true
  },
  "browserslist": {
    "development": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 140",
      "safari >= 18.4",
      "ios_saf >= 18.4"
    ],
    "production": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 140",
      "safari >= 18.4",
      "ios_saf >= 18.4",
      "and_chr >= 111"
    ]
  },
  "dependencies": {
    "freeport-async": "^2.0.0",
    "mcp-remote": "^0.1.38"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@bondery/schemas": "*",
    "@redocly/cli": "^2.38.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.10.4",
    "typescript": "^7.0.2",
    "yaml": "^2.9.0"
  },
  "name": "bondery-monorepo",
  "overrides": {
    "@tiptap/core": "3.27.1",
    "@tiptap/extension-bubble-menu": "3.27.1",
    "@tiptap/extension-color": "3.27.1",
    "@tiptap/extension-emoji": "3.27.1",
    "@tiptap/extension-floating-menu": "3.27.1",
    "@tiptap/extension-highlight": "3.27.1",
    "@tiptap/extension-link": "3.27.1",
    "@tiptap/extension-list": "3.27.1",
    "@tiptap/extension-mention": "3.27.1",
    "@tiptap/extension-placeholder": "3.27.1",
    "@tiptap/extension-task-item": "3.27.1",
    "@tiptap/extension-task-list": "3.27.1",
    "@tiptap/extension-text-style": "3.27.1",
    "@tiptap/extensions": "3.27.1",
    "@tiptap/pm": "3.27.1",
    "@tiptap/react": "3.27.1",
    "@tiptap/starter-kit": "3.27.1",
    "@tiptap/suggestion": "3.27.1",
    "next": "16.3.0-canary.83",
    "postcss": "^8.5.17",
    "zod-openapi": "^6.0.0"
  },
  "packageManager": "npm@11.12.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:api": "turbo build --filter=api",
    "build:chrome-extension": "turbo build --filter=chrome-extension",
    "build:webapp": "turbo build --filter=webapp",
    "build:website": "turbo build --filter=website",
    "check-api-error-translations": "node scripts/check-api-error-translations.mjs",
    "check-dev-ports": "node scripts/check-dev-ports.mjs",
    "check-doc-links": "node scripts/check-doc-links.mjs",
    "check-error-docs": "node scripts/check-error-docs.mjs",
    "check-openapi": "npm run check-openapi -w apps/api && npm run check-api-schema-patterns -w apps/api && npx redocly lint apps/api/openapi.yaml",
    "check-package-imports": "node scripts/check-package-import-extensions.mjs",
    "check-translations": "node packages/translations/scripts/check-bondery-i18n-rules.mjs",
    "check-types": "turbo check-types",
    "check-user-facing-errors": "node scripts/check-user-facing-errors.mjs",
    "compile:packages": "turbo compile --filter='./packages/*'",
    "dev": "turbo watch dev --concurrency 20",
    "dev:emails": "turbo watch @bondery/emails#preview --concurrency 20",
    "dev:extension": "turbo watch webapp#dev api#dev chrome-extension#dev website#dev --concurrency 20",
    "dev:polar-webhook": "npx localtunnel --port 26631",
    "dev:webapp-api": "turbo watch webapp#dev api#dev --concurrency 20",
    "dev:webapp-api-emails": "turbo watch webapp#dev api#dev @bondery/emails#preview --concurrency 20",
    "dev:website": "turbo watch website#dev --concurrency 20",
    "env": "node --import tsx scripts/env.ts",
    "generate-doc-links": "node scripts/generate-doc-links.mjs",
    "generate-openapi": "turbo generate-openapi --filter=api",
    "generate-types": "npm run gen-types -w apps/supabase-db && git add packages/schemas/src/supabase.types.ts",
    "i18n:lint": "npm run i18n:lint -w @bondery/translations",
    "i18n:status": "npm run i18n:status -w @bondery/translations",
    "i18n:status:check": "npm run i18n:status:check -w @bondery/translations",
    "i18n:types": "npm run i18n:types -w @bondery/translations",
    "i18n:types:check": "npm run i18n:types:check -w @bondery/translations",
    "lint": "biome check --write .",
    "mobile": "turbo watch api#dev mobile#dev --concurrency 20",
    "prepare": "husky",
    "setup:dev": "node --import tsx scripts/setup-dev.ts",
    "start": "turbo start",
    "sync-exports": "node scripts/sync-package-exports.mjs",
    "test:contracts": "npm run test:contracts -w @bondery/schemas",
    "tsc-native": "node scripts/tsc-native.mjs",
    "turbo:clean": "turbo daemon clean"
  },
  "version": "1.7.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
