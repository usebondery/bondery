    },
    "./database": {
      "types": "./src/supabase.types.ts",
      "default": "./dist/supabase.types.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "check-types": "tsc --noEmit",
    "test:contracts": "node scripts/check-no-internal-deps.mjs && npx tsx ./src/contracts.assertions.ts && npx tsx ./scripts/check-openapi-examples.ts"
  },
  "description": "Canonical types, Zod validation schemas, and constants for Bondery. Contract layer — no runtime business logic.",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "@bondery/typescript-config": "*",
    "typescript": "^6"
  },
  "imports": {
    "#*": [
      "./dist/*",
      "./dist/*.js",
      "./dist/*/index.js",
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  }
}
