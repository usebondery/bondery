      "types": "./src/entities/group.ts",
      "default": "./dist/entities/group.js"
    },
    "./entities/import": {
      "types": "./src/entities/import.ts",
      "default": "./dist/entities/import.js"
    },
    "./entities/important-date": {
      "types": "./src/entities/important-date.ts",
      "default": "./dist/entities/important-date.js"
    },
    "./entities/merge": {
      "types": "./src/entities/merge.ts",
      "default": "./dist/entities/merge.js"
    },
    "./entities/notes": {
      "types": "./src/entities/notes.ts",
