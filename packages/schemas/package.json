{
  "name": "@bondery/schemas",
  "version": "1.4.2",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "import": "./src/constants/index.ts",
      "node": "./dist/constants/index.js",
      "default": "./dist/constants/index.js"
    },
    "./supabase.types": {
      "types": "./src/supabase.types.ts",
      "import": "./src/supabase.types.ts",
      "node": "./dist/supabase.types.js",
      "default": "./dist/supabase.types.js"
    },
    "./database": {
      "types": "./src/supabase.types.ts",
      "import": "./src/supabase.types.ts",
      "node": "./dist/supabase.types.js",
      "default": "./dist/supabase.types.js"
    },
    "./sync": {
      "types": "./src/sync/index.ts",
      "import": "./src/sync/index.ts",
      "node": "./dist/sync/index.js",
      "default": "./dist/sync/index.js"
    },
    "./http": {
      "types": "./src/http/index.ts",
      "import": "./src/http/index.ts",
      "node": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc && node ../../scripts/fix-package-esm-imports.mjs",
    "check-types": "tsc --noEmit",
    "test:contracts": "node scripts/check-no-internal-deps.mjs && npx tsx ./src/contracts.assertions.ts"
  },
  "description": "Canonical types, Zod validation schemas, and constants for Bondery. Contract layer — no runtime business logic.",
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^6"
  }
}
