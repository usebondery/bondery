    "./openapi/fixtures/responses": {
      "types": "./src/openapi/fixtures/responses.ts",
      "default": "./dist/openapi/fixtures/responses.js"
    },
    "./openapi/get-schema-example": {
      "types": "./src/openapi/get-schema-example.ts",
      "default": "./dist/openapi/get-schema-example.js"
    },
    "./openapi/registry": {
      "types": "./src/openapi/registry.ts",
      "default": "./dist/openapi/registry.js"
