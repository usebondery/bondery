{
  "name": "@bondery/schemas",
  "version": "1.4.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./dist/constants/index.js"
    },
    "./entities": {
      "types": "./src/entities/index.ts",
      "default": "./dist/entities/index.js"
    },
    "./geocode": {
