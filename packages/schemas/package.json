    },
    "./http": {
      "types": "./src/http/index.ts",
      "default": "./dist/http/index.js"
    },
    "./openapi/fixtures": {
      "types": "./src/openapi/fixtures/index.ts",
      "default": "./dist/openapi/fixtures/index.js"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
