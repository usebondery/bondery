{
  "name": "@bondery/emails",
  "version": "1.4.2",
  "description": "Bondery email templates using React Email",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "email dev --dir ./src --port 3004",
    "build": "rimraf dist && tsc && node ../../scripts/fix-package-esm-imports.mjs"
  },
  "dependencies": {
    "@bondery/branding": "*",
    "@react-email/render": "^2.0.4",
    "@react-email/ui": "^6.6.0",
    "react-email": "^6.6.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@react-email/preview-server": "^5.2.11",
    "@types/react": "^19",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.1",
    "typescript": "^6"
  }
}
