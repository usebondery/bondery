{
  "dependencies": {
    "@bondery/branding": "*",
    "@bondery/helpers": "*",
    "@react-email/render": "^2.0.4",
    "@react-email/ui": "^6.6.0",
    "react-email": "^6.6.0"
  },
  "description": "Bondery email templates using React Email",
  "devDependencies": {
    "@bondery/typescript-config": "*",
    "@types/react": "^19",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.0.1",
    "typescript": "^6"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "import": "./dist/index.js",
      "node": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./*": {
      "default": "./dist/*.js",
      "import": "./dist/*.js",
      "node": "./dist/*.js",
      "types": "./src/*.ts"
    },
    "./shared/EmailWrapper": {
      "default": "./dist/shared/EmailWrapper.js",
      "import": "./dist/shared/EmailWrapper.js",
      "node": "./dist/shared/EmailWrapper.js",
      "types": "./src/shared/EmailWrapper.tsx"
    },
    "./templates/FeedbackEmail": {
      "default": "./dist/templates/FeedbackEmail.js",
      "import": "./dist/templates/FeedbackEmail.js",
      "node": "./dist/templates/FeedbackEmail.js",
      "types": "./src/templates/FeedbackEmail.tsx"
    },
    "./templates/ReminderDigestEmail": {
      "default": "./dist/templates/ReminderDigestEmail.js",
      "import": "./dist/templates/ReminderDigestEmail.js",
      "node": "./dist/templates/ReminderDigestEmail.js",
      "types": "./src/templates/ReminderDigestEmail.tsx"
    },
    "./templates/ShareContactEmail": {
      "default": "./dist/templates/ShareContactEmail.js",
      "import": "./dist/templates/ShareContactEmail.js",
      "node": "./dist/templates/ShareContactEmail.js",
      "types": "./src/templates/ShareContactEmail.tsx"
    }
  },
  "files": [
    "src"
  ],
  "imports": {
    "#*": [
      "./dist/*",
      "./dist/*.js",
      "./dist/*/index.js",
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "main": "./dist/index.js",
  "name": "@bondery/emails",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "build": "rimraf dist && tsc && node ../../scripts/rewrite-package-hash-imports-in-dist.mjs emails",
    "compile": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "preview": "email dev --dir ./src --port 26639"
  },
  "type": "module",
  "types": "./src/index.ts",
  "version": "1.7.0"
}
