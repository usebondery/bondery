{
  "name": "@bondery/branding",
  "version": "1.4.2",
  "type": "module",
  "description": "Bondery branding assets and icons",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./src": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./icon-generator": {
      "types": "./scripts/icon-generator.d.ts",
      "import": "./scripts/generate-icons.ts",
      "require": "./scripts/generate-icons.ts"
    },
    "./icons": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts",
      "require": "./src/react/index.ts"
    },
    "./react": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts",
      "require": "./src/react/index.ts"
    },
    "./react/src": {
      "types": "./src/react/index.ts",
      "import": "./src/react/index.ts",
      "require": "./src/react/index.ts"
    }
  },
  "files": [
    "src",
    "scripts",
    "src/assets"
  ],
  "scripts": {
    "build:types": "rimraf dist && tsc && node scripts/fix-esm-imports.mjs"
  },
  "dependencies": {
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/node": "^25",
    "rimraf": "^6.0.1",
    "tsx": "^4.21.0",
    "typescript": "^6"
  }
}
