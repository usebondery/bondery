{
  "dependencies": {
    "sharp": "^0.35.3"
  },
  "description": "Bondery branding assets and icons",
  "devDependencies": {
    "@bondery/typescript-config": "*",
    "@types/node": "^26",
    "@types/react": "^19",
    "react": "^19.2.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "import": "./dist/index.js",
      "node": "./dist/index.js",
      "types": "./src/index.ts"
    },
    "./*": {
      "default": "./dist/*.js",
      "import": "./dist/*.js",
      "node": "./dist/*.js",
      "types": "./src/*.ts"
    },
    "./icon-generator": {
      "default": "./scripts/generate-icons.ts",
      "types": "./scripts/icon-generator.d.ts"
    },
    "./react": {
      "default": "./dist/react/index.js",
      "import": "./dist/react/index.js",
      "node": "./dist/react/index.js",
      "types": "./src/react/index.ts"
    },
    "./react/BonderyIcon": {
      "default": "./dist/react/BonderyIcon.js",
      "import": "./dist/react/BonderyIcon.js",
      "node": "./dist/react/BonderyIcon.js",
      "types": "./src/react/BonderyIcon.tsx"
    },
    "./react/BonderyIconWhite": {
      "default": "./dist/react/BonderyIconWhite.js",
      "import": "./dist/react/BonderyIconWhite.js",
      "node": "./dist/react/BonderyIconWhite.js",
      "types": "./src/react/BonderyIconWhite.tsx"
    },
    "./react/BonderyLogotypeBlack": {
      "default": "./dist/react/BonderyLogotypeBlack.js",
      "import": "./dist/react/BonderyLogotypeBlack.js",
      "node": "./dist/react/BonderyLogotypeBlack.js",
      "types": "./src/react/BonderyLogotypeBlack.tsx"
    },
    "./react/BonderyLogotypeWhite": {
      "default": "./dist/react/BonderyLogotypeWhite.js",
      "import": "./dist/react/BonderyLogotypeWhite.js",
      "node": "./dist/react/BonderyLogotypeWhite.js",
      "types": "./src/react/BonderyLogotypeWhite.tsx"
    },
    "./react/index.d": {
      "default": "./dist/react/index.d.js",
      "import": "./dist/react/index.d.js",
      "node": "./dist/react/index.d.js",
      "types": "./src/react/index.d.ts"
    }
  },
  "files": [
    "src",
    "scripts",
    "src/assets"
  ],
  "imports": {
    "#*": [
      "./dist/*",
      "./dist/*.js",
      "./dist/*/index.js",
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  },
  "main": "./dist/index.js",
  "name": "@bondery/branding",
  "peerDependencies": {
    "react": "^19.2.7"
  },
  "scripts": {
    "build": "rimraf dist tsconfig.tsbuildinfo && tsc && node ../../scripts/rewrite-package-hash-imports-in-dist.mjs branding",
    "compile": "tsc",
    "dev": "tsc --watch --preserveWatchOutput"
  },
  "type": "module",
  "types": "./src/index.ts",
  "version": "1.7.4"
}
