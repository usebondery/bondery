{
  "name": "@bondery/mantine-next",
  "version": "1.4.2",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./src/theme.ts",
      "node": "./dist/theme.js",
      "import": "./src/theme.ts",
      "default": "./dist/theme.js"
    },
    "./theme/src": {
      "types": "./src/theme.ts",
      "node": "./dist/theme.js",
      "import": "./src/theme.ts",
      "default": "./dist/theme.js"
    },
    "./styles": {
      "types": "./src/styles.d.ts",
      "style": "./src/styles.css",
      "import": "./src/styles.css",
      "require": "./src/styles.css"
    }
  },
  "dependencies": {
    "@bondery/branding": "*",
    "@bondery/helpers": "*",
    "@bondery/schemas": "*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "scripts": {
    "build": "rimraf dist && tsc && node ../../scripts/fix-package-esm-imports.mjs",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^6"
  },
  "peerDependencies": {
    "@mantine/code-highlight": "^9.0.0",
    "@mantine/core": "^9.0.0",
    "@mantine/dropzone": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@tabler/icons-react": "^3.34.1",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
