{
  "name": "@bondery/mantine-next",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "require": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./theme": {
      "import": "./src/theme.ts",
      "require": "./src/theme.ts",
      "types": "./src/theme.ts"
    },
    "./theme/src": {
      "import": "./src/theme.ts",
      "require": "./src/theme.ts",
      "types": "./src/theme.ts"
    },
    "./styles": {
      "style": "./src/styles.css",
      "import": "./src/styles.css",
      "require": "./src/styles.css"
    }
  },
  "dependencies": {
    "@bondery/branding": "*",
    "@bondery/helpers": "*",
    "@bondery/types": "*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "peerDependencies": {
    "@mantine/core": "^8.3.11",
    "@mantine/dropzone": "^8.3.11",
    "@mantine/hooks": "^8.3.11",
    "@tabler/icons-react": "^3.34.1",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
