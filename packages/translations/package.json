{
  "name": "@bondery/translations",
  "version": "1.4.2",
  "description": "Bondery internationalization translations",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts",
      "node": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./i18n": {
      "types": "./src/i18n.ts",
      "import": "./src/i18n.ts",
      "node": "./dist/i18n.js",
      "default": "./dist/i18n.js"
    },
    "./*.json": {
      "default": "./dist/*.json"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc && node ../../scripts/rewrite-package-hash-imports-in-dist.mjs translations && node scripts/copy-json.mjs",
    "dev": "tsc --watch --preserveWatchOutput",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "@bondery/typescript-config": "*",
    "typescript": "^6"
  },
  "imports": {
    "#*": [
      "./dist/*",
      "./dist/*.js",
      "./dist/*/index.js",
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  }
}
