{
  "name": "@bondery/translations",
  "version": "1.4.2",
  "description": "Bondery internationalization translations",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "node": "./dist/index.js",
      "import": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./cs": {
      "default": "./dist/cs.json",
      "import": "./src/cs.json"
    },
    "./en": {
      "default": "./dist/en.json",
      "import": "./src/en.json"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "rimraf dist && tsc && node scripts/copy-json.mjs && node ../../scripts/fix-package-esm-imports.mjs",
    "check-types": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^6"
  }
}
