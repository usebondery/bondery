{
  "name": "@bondery/vcard",
  "version": "1.4.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./dist/*.js",
      "node": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./attachments": {
      "types": "./src/attachments.ts",
      "import": "./dist/attachments.js",
      "node": "./dist/attachments.js",
      "default": "./dist/attachments.js"
    },
    "./contact-mapping": {
      "types": "./src/contact-mapping.ts",
      "import": "./dist/contact-mapping.js",
      "node": "./dist/contact-mapping.js",
      "default": "./dist/contact-mapping.js"
    },
    "./model": {
      "types": "./src/model.ts",
      "import": "./dist/model.js",
      "node": "./dist/model.js",
      "default": "./dist/model.js"
    },
    "./parse": {
      "types": "./src/parse.ts",
      "import": "./dist/parse.js",
      "node": "./dist/parse.js",
      "default": "./dist/parse.js"
    },
    "./serialize": {
      "types": "./src/serialize.ts",
      "import": "./dist/serialize.js",
      "node": "./dist/serialize.js",
      "default": "./dist/serialize.js"
    }
  },
  "scripts": {
    "build": "rimraf dist && tsc && node ../../scripts/rewrite-package-hash-imports-in-dist.mjs vcard",
    "dev": "tsc --watch --preserveWatchOutput",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@bondery/helpers": "*",
    "@bondery/schemas": "*"
  },
  "devDependencies": {
    "@types/node": "^25",
    "rimraf": "^6.0.1",
    "@bondery/typescript-config": "*",
    "typescript": "^6"
  },
  "imports": {
    "#*": [
      "./dist/*",
      "./dist/*.js",
      "./dist/*/index.js",
      "./src/*",
      "./src/*.ts",
      "./src/*.tsx",
      "./src/*/index.ts",
      "./src/*/index.tsx"
    ]
  }
}
