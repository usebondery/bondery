# Copy this file to .env in the same folder and fill real values.
# Expo only exposes variables prefixed with EXPO_PUBLIC_.

# API base URL (without trailing /api).
# On Android emulator, localhost/127.0.0.1 is auto-mapped to 10.0.2.2 at runtime.
EXPO_PUBLIC_API_URL=http://127.0.0.1:3001

# Supabase project URL.
# On Android emulator, localhost/127.0.0.1 is auto-mapped to 10.0.2.2 at runtime.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/publishable key.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Optional website URL used in legal links on login screen.
EXPO_PUBLIC_WEBSITE_URL=https://usebondery.com

# Optional: cap Metro transform workers when you hit EMFILE (too many open files).
# Leave unset for fastest dev load. If needed, try 4 first, then 2.
# METRO_MAX_WORKERS=4
