{
  "name": "api",
  "version": "1.7.0",
  "private": true,
  "type": "module",
  "description": "Bondery API",
  "scripts": {
    "dev": "npm run check-env && tsx watch --env-file=.env.development.local src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "check-types": "tsx scripts/check-api-schema-patterns.ts && tsc --noEmit",
    "check-openapi": "npm run generate-openapi && tsx scripts/check-openapi.ts && tsx scripts/check-api-route-order.ts",
    "check-api-schema-patterns": "tsx scripts/check-api-schema-patterns.ts",
    "check-env": "tsx scripts/check-env.ts",
    "test:sync": "tsx --test src/lib/sync/build-changes.test.ts src/lib/sync/emit-wake.test.ts src/lib/sync/wake/hub.test.ts src/lib/sync/wake/tickets.test.ts src/lib/sync/wake/in-memory-bus.test.ts",
    "generate-openapi": "tsx scripts/generate-openapi.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@bondery/emails": "*",
    "@bondery/helpers": "*",
    "@bondery/schemas": "*",
    "@bondery/vcard": "*",
    "@fastify/auth": "^5.0.4",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/websocket": "^11.2.0",
    "@polar-sh/sdk": "^0.48.1",
    "@react-email/render": "^2.0.4",
    "@supabase/supabase-js": "^2.99.3",
    "adm-zip": "^0.5.16",
    "ai": "^6.0.206",
    "csv-parse": "^7.0.0",
    "fastify": "^5.8.2",
    "fastify-zod-openapi": "^5.6.1",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "js-sha3": "^0.9.3",
    "nodemailer": "^9.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^25",
    "@types/nodemailer": "^8.0.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6"
  }
}
