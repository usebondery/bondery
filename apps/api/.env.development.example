# Configuration that is used for development build locally

## App URLs
NEXT_PUBLIC_WEBAPP_URL="http://localhost:26632"
NEXT_PUBLIC_WEBSITE_URL="http://localhost:26630"
NEXT_PUBLIC_API_URL="http://localhost:26631"
## Comma-separated extra origins for CORS (e.g. Expo web dev server)
EXTRA_ALLOWED_ORIGINS="http://localhost:26634"

## Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_<your-publishable-key>"
PRIVATE_SUPABASE_SECRET_KEY="sb_secret_<your-secret-key>"

## Analytics (optional)
DO_NOT_TRACK=true

## Email Configuration (for feedback notifications)
PRIVATE_EMAIL_HOST="smtp.example.com"
PRIVATE_EMAIL_PORT=465
PRIVATE_EMAIL_USER="robot@example.com"
PRIVATE_EMAIL_PASS="your-email-password"
PRIVATE_EMAIL_ADDRESS="robot@example.com"

## Maps / Geocoding (mapy.com)
PUBLIC_MAPS_URL="https://api.mapy.com"
PRIVATE_MAPS_KEY="<your-maps-api-key>"

## AI Chat
PRIVATE_ANTHROPIC_API_KEY="sk-ant-<your-anthropic-api-key>"

## Polar.sh Payments
# From: sandbox.polar.sh → Settings → Webhooks → (your endpoint) → Signing Secret
PRIVATE_POLAR_WEBHOOK_SECRET="<your-polar-webhook-secret>"
PRIVATE_POLAR_ACCESS_TOKEN="<your-polar-access-token>"
PUBLIC_POLAR_ENVIRONMENT="sandbox"
POLAR_PRODUCT_ID="<your-polar-product-id>"

## Redis (rate limits, sync wake, WS tickets)
# Default: local Docker Redis — npm run start -w redis  (port 26636 / DEV_REDIS_URL)
PRIVATE_REDIS_URL="redis://127.0.0.1:26636"
# In-memory fallback (no Docker Redis): uncomment and clear the line above
# PRIVATE_REDIS_URL=""

## API keys (long-lived integration tokens)
# Pepper for hashing API keys at rest — use a random secret, at least 32 characters.
# Generate: openssl rand -hex 32
PRIVATE_API_KEY_PEPPER="<your-api-key-pepper>"
# ES256 private JWK for minting user JWTs after API key auth (full JSON, one line).
# Setup: docs/contributing/local-setup.md#api-keys-long-lived-integration-tokens
PRIVATE_SUPABASE_JWT_SIGNING_JWK='{"kty":"EC","kid":"<your-kid>","use":"sig","alg":"ES256","crv":"P-256","d":"<private-d>","x":"<public-x>","y":"<public-y>"}'