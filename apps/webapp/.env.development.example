
# Configuration that is used for development build locally

## App URLs
NEXT_PUBLIC_WEBAPP_URL="http://localhost:3002"
NEXT_PUBLIC_WEBSITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3001"

## Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_<your-publishable-key>"
# Required for webhook handler to write subscription rows bypassing RLS
SUPABASE_SERVICE_ROLE_KEY="<your-supabase-service-role-key>"
NEXT_PUBLIC_MAPS_URL="https://api.mapy.com"
NEXT_PRIVATE_MAPS_KEY=""

## Analytics (optional)
DO_NOT_TRACK=true
NEXT_TELEMETRY_DISABLED=1

## Polar.sh Payments
# Use "sandbox" for local dev, "production" for live
POLAR_ENVIRONMENT="sandbox"
# From: sandbox.polar.sh → Settings → Developers → Access Tokens
POLAR_ACCESS_TOKEN="<your-polar-access-token>"
# Note: POLAR_WEBHOOK_SECRET has moved to apps/api env — configure it there
# From: sandbox.polar.sh → Products → (your product) → copy the product ID
POLAR_PRODUCT_ID="<your-polar-product-id>"