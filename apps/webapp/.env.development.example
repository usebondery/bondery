# Configuration that is used for development build locally

## App URLs
NEXT_PUBLIC_WEBAPP_URL="http://localhost:26632"
NEXT_PUBLIC_WEBSITE_URL="http://localhost:26630"
NEXT_PUBLIC_API_URL="http://localhost:26631"

## Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_<your-publishable-key>"

## Build metadata (optional, surfaced via /runtime-config.json)
BONDERY_VERSION=
BONDERY_GIT_SHA=

## Analytics (optional)
DO_NOT_TRACK=true
NEXT_TELEMETRY_DISABLED=1