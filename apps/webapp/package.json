{
  "name": "webapp",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "description": "Bondery Webapp",
  "scripts": {
    "check-env": "tsx scripts/check-env.ts",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "predev": "cross-env NODE_ENV=development npm run generate-icons",
    "prebuild": "cross-env NODE_ENV=production npm run generate-icons",
    "dev": "next dev --port 3002",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check-types": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 113",
      "safari >= 16.4",
      "ios_saf >= 16.4",
      "and_chr >= 111"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@bondery/branding": "*",
    "@bondery/helpers": "*",
    "@bondery/mantine-next": "*",
    "@bondery/translations": "*",
    "@bondery/types": "*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mantine/core": "^8.3.18",
    "@mantine/dates": "^8.3.18",
    "@mantine/dropzone": "^8.3.18",
    "@mantine/form": "^8.3.18",
    "@mantine/hooks": "^8.3.18",
    "@mantine/modals": "^8.3.18",
    "@mantine/notifications": "^8.3.18",
    "@mantine/tiptap": "^8.3.18",
    "@mantine/charts": "^8.3.18",
    "@maplibre/maplibre-gl-leaflet": "^0.1.3",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tabler/icons-react": "^3.40.0",
    "@tiptap/extension-color": "^3.20.4",
    "@tiptap/extension-emoji": "^3.20.4",
    "@tiptap/extension-highlight": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-mention": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-task-item": "^3.20.4",
    "@tiptap/extension-task-list": "^3.20.4",
    "@tiptap/extension-text-style": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@tiptap/suggestion": "^3.20.4",
    "@types/d3": "^7.4.3",
    "@vvo/tzdb": "^6.198.0",
    "d3": "^7.9.0",
    "dayjs": "^1.11.20",
    "flag-icons": "^7.5.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "maplibre-gl": "^5.21.0",
    "motion": "^12.38.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "posthog-js": "^1.363.1",
    "posthog-node": "^5.21.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-imask": "^7.6.1",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.0.0",
    "recharts": "^2.15.3",
    "tippy.js": "^6.3.7"
