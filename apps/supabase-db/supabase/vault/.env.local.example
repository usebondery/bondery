## Local API base URL reachable from Supabase Docker containers.
## Keep the internal API port (3001) in local development.
NEXT_PUBLIC_API_URL="http://host.docker.internal:3001"

## Shared handshake secret between Supabase-triggered HTTP calls and API route auth.
PRIVATE_BONDERY_SUPABASE_HTTP_KEY="bondery<your-handshake-key>"

## Secrets used by send_hourly_reminder_digests() are stored in Supabase Vault, not as GUCs.
## Run these once in the SQL editor to register them (or update via vault.update_secret):
##
##   SELECT vault.create_secret(
##     'http://host.docker.internal:3001',
##     'next_public_api_url',
##     'API base URL for reminder HTTP dispatch'
##   );
##
##   SELECT vault.create_secret(
##     'bondery<your-handshake-key>',
##     'private_bondery_supabase_http_key',
##     'Shared secret for Supabase -> API HTTP calls'
##   );
##
## Verify: SELECT name, updated_at FROM vault.secrets WHERE name IN ('next_public_api_url', 'private_bondery_supabase_http_key');
