{
  "name": "website",
  "version": "1.4.2",
  "private": true,
  "description": "Bondery Website",
  "scripts": {
    "check-env": "tsx scripts/check-env.ts",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "announce": "tsx --env-file=../../.env.local scripts/announce.ts",
    "predev": "cross-env NODE_ENV=development npm run check-env && npm run generate-icons",
    "prebuild": "cross-env NODE_ENV=production npm run check-env && npm run generate-icons",
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint .",
    "check-types": "tsc --noEmit"
  },
  "browserslist": {
    "production": [
      "chrome >= 111",
      "edge >= 111",
      "firefox >= 113",
      "safari >= 16.4",
      "ios_saf >= 16.4",
      "and_chr >= 111"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@bondery/branding": "*",
    "@bondery/helpers": "*",
    "@bondery/mantine-next": "*",
    "@bondery/translations": "*",
    "@mantine/core": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@mantine/notifications": "^9.0.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@tabler/icons-react": "^3.40.0",
    "i18next": "^26.3.3",
    "motion": "^12.38.0",
    "next": "^16.2.1",
    "next-i18next": "^16.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6"
  }
}
