{
  "dependencies": {
    "@bondery/branding": "*",
    "@bondery/helpers": "*",
    "@bondery/mantine-next": "*",
    "@bondery/schemas": "*",
    "@bondery/translations": "*",
    "@mantine/core": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@mantine/notifications": "^9.0.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.1",
    "@tabler/icons-react": "^3.40.0",
    "i18next": "^26.3.3",
    "motion": "^12.38.0",
    "next": "^16.2.1",
    "next-i18next": "^16.0.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8"
  },
  "description": "Bondery Website",
  "devDependencies": {
    "@bondery/typescript-config": "*",
    "@tailwindcss/postcss": "^4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^6"
  },
  "name": "website",
  "private": true,
  "scripts": {
    "announce": "tsx --env-file=../../.env.local scripts/announce.ts",
    "build": "next build",
    "check-env": "tsx scripts/check-env.ts",
    "check-types": "tsc --noEmit",
    "dev": "next dev --port 26630",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "prebuild": "cross-env NODE_ENV=production npm run check-env && npm run generate-icons",
    "predev": "cross-env NODE_ENV=development npm run check-env && npm run generate-icons",
    "start": "next start"
  },
  "version": "1.7.0"
}
