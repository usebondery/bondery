{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "target": "ES2017"
  },
  "exclude": ["node_modules"],
  "extends": "@bondery/typescript-config/nextjs.json",
  "include": [
    "next-env.d.ts",
    "mdx.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mdx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "../../packages/translations/src/generated/i18next-cli/i18next.d.ts"
  ]
}
