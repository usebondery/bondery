{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["chrome", "node"],
    "paths": {
      "@bondery/helpers": ["../../packages/helpers/src/index.ts"],
      "@bondery/helpers/name-utils": ["../../packages/helpers/src/name-utils.ts"],
      "@bondery/branding-src": ["../../packages/branding/src/index.ts"]
    }
  },
  "include": ["src/**/*", "scripts/**/*", "wxt.config.ts"],
  "exclude": ["node_modules", "dist", ".output", ".wxt"]
}
