
# =====================================================
# Chrome Extension - Production Environment
# =====================================================
# Copy this file to .env.production.local and fill in the values
# WXT requires the WXT_ or VITE_ prefix for environment variables

## App URLs
WXT_WEBAPP_URL="https://app.usebondery.com"
WXT_API_URL="https://app.usebondery.com"

## Supabase Configuration
WXT_SUPABASE_URL="https://slusayyjuoxwoukhjjqh.supabase.co"

## OAuth Configuration
# Get this from Supabase Dashboard -> Authentication -> Providers -> OAuth (Extension)
WXT_OAUTH_CLIENT_ID=""

# =====================================================
# CI/CD Variables (only needed for publishing)
# =====================================================
# GOOGLE_CLIENT_ID - Chrome Web Store client ID
# GOOGLE_CLIENT_SECRET - Chrome Web Store client secret
# GOOGLE_REFRESH_TOKEN - OAuth refresh token for CWS API
# CHROME_WEB_STORE_EXTENSION_ID - Extension ID in Chrome Web Store