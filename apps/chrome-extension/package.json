{
  "name": "chrome-extension",
  "version": "1.4.2",
  "private": true,
  "type": "module",
  "description": "Bondery Extension",
  "scripts": {
    "dev": "npx wxt",
    "dev:firefox": "npx wxt -b firefox",
    "prebuild": "tsx scripts/check-env.ts && tsx scripts/generate-icons.ts",
    "build": "npx wxt build",
    "build:firefox": "npx wxt build -b firefox",
    "zip": "npx wxt zip",
    "zip:firefox": "npx wxt zip -b firefox",
    "postinstall": "npx wxt prepare",
    "check-env": "tsx scripts/check-env.ts",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "check-types": "tsc --noEmit",
    "lint": "biome lint src"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "@types/node": "^25",
    "@wxt-dev/module-react": "^1.2.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "sharp": "^0.35.1",
    "tsx": "^4.21.0",
    "typescript": "^6",
    "wxt": "^0.20.20"
  },
  "dependencies": {
    "@bondery/branding": "*",
    "@bondery/helpers": "*",
    "@bondery/mantine-next": "*",
    "@bondery/schemas": "*",
    "@mantine/core": "^9.0.0",
    "@mantine/hooks": "^9.0.0",
    "@tabler/icons-react": "^3.40.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "transliteration": "^2.6.1"
  }
}
