{
  "dependencies": {
    "@bondery/branding": "*",
    "@bondery/helpers": "*",
    "@bondery/mantine-next": "*",
    "@bondery/schemas": "*",
    "@bondery/translations": "*",
    "@mantine/core": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@tabler/icons-react": "^3.44.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "flag-icons": "^7.5.0",
    "i18next": "^26.3.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.9",
    "transliteration": "^2.6.1"
  },
  "description": "Bondery Extension",
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/node": "^26",
    "@vitejs/plugin-react": "^6.0.3",
    "@wxt-dev/module-react": "^1.2.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "sharp": "^0.35.3",
    "tsx": "^4.23.0",
    "wxt": "^0.20.27"
  },
  "name": "chrome-extension",
  "private": true,
  "scripts": {
    "build": "npx wxt build",
    "build:firefox": "npx wxt build -b firefox",
    "check-env": "tsx scripts/check-env.ts",
    "check-extension-patterns": "tsx scripts/check-extension-patterns.ts",
    "check-types": "node ../../scripts/tsc-native.mjs --noEmit",
    "dev": "npx wxt",
    "dev:firefox": "npx wxt -b firefox",
    "generate-icons": "tsx scripts/generate-icons.ts",
    "postinstall": "npm run build -w @bondery/schemas && npx wxt prepare",
    "prebuild": "tsx scripts/check-env.ts && tsx scripts/generate-icons.ts",
    "zip": "npx wxt zip",
    "zip:firefox": "npx wxt zip -b firefox"
  },
  "type": "module",
  "version": "1.7.3"
}
